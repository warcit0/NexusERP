@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success">
            <MudTextField T="string" @bind-Value="model.Name" Label="Nombre de la Empresa" 
                          Required="true" RequiredError="El nombre es requerido" Class="mb-3"/>
                          
            <MudTextField T="string" @bind-Value="model.Subdomain" Label="Subdominio (Opcional)" 
                          HelperText="Ej: miempresa (para miempresa.nexuserp.com)" Class="mb-3"/>
                          
            <MudTextField T="string" @bind-Value="model.AdminEmail" Label="Correo del Administrador" 
                          Required="true" RequiredError="El correo es requerido" InputType="InputType.Email" Class="mb-3"/>
                          
            <MudTextField T="string" @bind-Value="model.AdminPassword" Label="Contraseña Temporal" 
                          Required="true" RequiredError="La contraseña es requerida" InputType="InputType.Password" Class="mb-3"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@loading">
            @if(loading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
            }
            else
            {
                <MudText>Crear</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    private MudForm form = null!;
    private bool success;
    private bool loading = false;
    private CreateTenantCommand model = new();

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            loading = true;
            try
            {
                var response = await Http.PostAsJsonAsync("api/v1/platform/tenants", model);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Empresa creada exitosamente", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    Snackbar.Add("Error al crear la empresa. Verifique los datos.", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add("Error de conexión: " + ex.Message, Severity.Error);
            }
            finally
            {
                loading = false;
            }
        }
    }

    public class CreateTenantCommand
    {
        public string Name { get; set; } = string.Empty;
        public string Subdomain { get; set; } = string.Empty;
        public string AdminEmail { get; set; } = string.Empty;
        public string AdminPassword { get; set; } = string.Empty;
    }
}
