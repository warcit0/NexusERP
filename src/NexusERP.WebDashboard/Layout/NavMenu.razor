<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
    
    <AuthorizeView Roles="SuperAdmin">
        <Authorized>
            <MudNavGroup Title="Plataforma" Icon="@Icons.Material.Filled.Settings" Expanded="true">
                <MudNavLink Href="/platform/tenants" Icon="@Icons.Material.Filled.Business">Empresas (Tenants)</MudNavLink>
                <MudNavLink Href="/platform/plans" Icon="@Icons.Material.Filled.CardMembership">Planes</MudNavLink>
                <MudNavLink Href="/platform/licenses" Icon="@Icons.Material.Filled.Key">Licencias</MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="TenantAdmin">
        <Authorized>
            <MudNavGroup Title="Administración" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="true">
                <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">Usuarios</MudNavLink>
                <MudNavLink Href="/admin/branches" Icon="@Icons.Material.Filled.Store">Sucursales</MudNavLink>
                <MudNavLink Href="/admin/registers" Icon="@Icons.Material.Filled.PointOfSale">Cajas</MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>

    <MudNavGroup Title="Ventas" Icon="@Icons.Material.Filled.ShoppingCart">
        <MudNavLink Href="/sales/new" Icon="@Icons.Material.Filled.AddShoppingCart">Nueva Venta</MudNavLink>
        <MudNavLink Href="/sales/history" Icon="@Icons.Material.Filled.History">Historial</MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Inventario" Icon="@Icons.Material.Filled.Inventory">
        <MudNavLink Href="/inventory/products" Icon="@Icons.Material.Filled.Category">Productos</MudNavLink>
        <MudNavLink Href="/inventory/stock" Icon="@Icons.Material.Filled.Warehouse">Existencias</MudNavLink>
    </MudNavGroup>
</MudNavMenu>
